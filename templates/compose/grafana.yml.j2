---
# {{ ansible_managed }}
version: "3"

services:
  grafana:
    image: {{ pssid_grafana_image }}
    container_name: grafana
    environment:
      - GF_INSTALL_PLUGINS=grafana-opensearch-datasource
      - GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=esnet-matrix-panel
{% if pssid_grafana_google_sso_enabled %}
      - GF_AUTH_GOOGLE_ENABLED=true
      - GF_AUTH_GOOGLE_CLIENT_ID={{ pssid_grafana_google_client_id }}
      - GF_AUTH_GOOGLE_CLIENT_SECRET={{ pssid_grafana_google_client_secret }}
      - GF_AUTH_GOOGLE_ALLOWED_DOMAINS={{ pssid_grafana_google_allowed_domains }}
      - GF_AUTH_GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/cloud-identity.groups.readonly
      - GF_AUTH_BASIC_ENABLED=false
      - GF_AUTH_ANONYMOUS_ENABLED=false
{% endif %}
{% if pssid_grafana_smtp_enabled %}
      - GF_SMTP_ENABLED=true
      - GF_SMTP_HOST={{ pssid_grafana_smtp_host }}
      - GF_SMTP_USER={{ pssid_grafana_smtp_user }}
      - GF_SMTP_PASSWORD={{ pssid_grafana_smtp_password }}
      - GF_SMTP_FROM_ADDRESS={{ pssid_grafana_smtp_user }}
      - GF_SMTP_FROM_NAME={{ pssid_grafana_smtp_from_name }}
{% endif %}
      - GF_SERVER_ROOT_URL={{ pssid_grafana_root_url }}
    volumes:
      - grafana-data:/var/lib/grafana
      - {{ pssid_pipeline_dir }}/plugins:/var/lib/grafana/plugins
      - {{ pssid_pipeline_dir }}/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ pssid_pipeline_dir }}/grafana/dashboards:/var/lib/grafana/dashboards:ro
{% if not pssid_enable_https %}
    ports:
      - "3000:3000"
{% endif %}
    networks: [opensearch-net]
    restart: always
{% if pssid_enable_https %}

  # HTTPS termination + ACME challenge via nginx + certbot
  nginx:
    image: nginx:1.27-alpine
    container_name: nginx
    volumes:
      - {{ pssid_pipeline_dir }}/nginx/conf.d:/etc/nginx/conf.d:ro
      - {{ pssid_pipeline_dir }}/nginx/certbot-www:/var/www/certbot          # ACME webroot
      - {{ pssid_pipeline_dir }}/nginx/letsencrypt:/etc/letsencrypt           # live certs
    ports:
      - "80:80"     # ACME HTTP-01 challenge
      - "443:443"   # HTTPS for users
    depends_on: [grafana]
    networks: [opensearch-net]
    restart: always

  certbot:
    image: certbot/certbot:latest
    container_name: certbot
    volumes:
      - {{ pssid_pipeline_dir }}/nginx/certbot-www:/var/www/certbot
      - {{ pssid_pipeline_dir }}/nginx/letsencrypt:/etc/letsencrypt
    entrypoint: >
      sh -c "trap exit TERM;
             while :; do
               certbot renew --webroot -w /var/www/certbot --quiet;
               sleep 12h & wait $${!};
             done"
    networks: [opensearch-net]
    depends_on: [nginx]
    restart: always
{% endif %}

volumes:
  grafana-data:

networks:
  opensearch-net:
    external:
      name: {{ pssid_docker_network_name }}
