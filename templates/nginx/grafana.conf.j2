## {{ ansible_managed }}
{% if not (pssid_https_cert_present | default(false)) %}
## Bootstrap phase: plain-HTTP server - handles the ACME challenge and
## proxies everything else so Grafana is reachable while the cert is issued.
server {
    listen 80;
    server_name {{ pssid_pipeline_hostname }};

    root /var/www/certbot;
    location /.well-known/acme-challenge/ { allow all; }

    location / {
        proxy_pass http://grafana:3000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
    }
}
{% else %}
## HTTPS phase: redirect HTTP -> HTTPS (still serving the ACME challenge for
## renewals) and terminate TLS with the issued Let's Encrypt certificate.
server {
    listen 80;
    server_name {{ pssid_pipeline_hostname }};

    root /var/www/certbot;
    location /.well-known/acme-challenge/ { allow all; }

    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl;
    http2 on;
    server_name {{ pssid_pipeline_hostname }};

    ssl_certificate     /etc/letsencrypt/live/{{ pssid_pipeline_hostname }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ pssid_pipeline_hostname }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://grafana:3000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
{% endif %}
